generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Material {
  id           String          @id @default(uuid())
  name         String
  imageUrl     String          @map("image_url")
  displayOrder Int             @map("display_order")
  createdAt    DateTime        @default(now()) @map("created_at")
  layouts      LayoutDetail[]

  @@map("materials")
}

model Customer {
  id          Int      @id @default(autoincrement())
  customerId  String   @unique @map("customer_id")
  companyName String   @map("company_name")
  emailDomain String   @map("email_domain")
  email       String?
  phone       String?
  address     String?
  notes       String?
  companyType String?  @map("company_type")
  memberName  String?  @map("member_name")
  memberTitle String?  @map("member_title")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  members     Member[]
  translations TranslationTable[]
  fonts       FontFamily[]

  @@map("customers")
}

model Member {
  id         Int      @id @default(autoincrement())
  memberId   String   @unique @map("member_id")
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [customerId], onDelete: Cascade)
  name       String
  title      String?
  email      String?
  phone      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("members")
}

model TranslationTable {
  id         Int       @id @default(autoincrement())
  name       String    @map("table_name")
  customerId String?   @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [customerId], onDelete: SetNull)
  data       String
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("translations")
}

model FontFamily {
  id         Int       @id @default(autoincrement())
  name       String    @map("font_name")
  fileName   String    @map("filename")
  filePath   String    @map("file_path")
  customerId String?   @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [customerId], onDelete: SetNull)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("fonts")
}

model Layout {
  id        String          @id @default(uuid())
  name      String          @unique
  details   LayoutDetail?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("layouts")
}

model LayoutDetail {
  id                  String   @id @default(uuid())
  layoutId            String   @unique @map("layout_id")
  layout              Layout   @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  materialId          String   @map("material_id")
  material            Material @relation(fields: [materialId], references: [id])
  widthMm             Float    @map("width_mm")
  heightMm            Float    @map("height_mm")
  orientation         String
  cuttingType         String   @map("cutting_type")
  loopFoldOrientation String?  @map("loop_fold_orientation")
  loopMidForm         Boolean? @map("loop_mid_form")
  loopFoldDistanceMm  Float?   @map("loop_fold_distance_mm")
  paddingOption       String   @map("padding_option")
  paddingTop          Float    @default(0) @map("padding_top")
  paddingRight        Float    @default(0) @map("padding_right")
  paddingBottom       Float    @default(0) @map("padding_bottom")
  paddingLeft         Float    @default(0) @map("padding_left")
  paddingR2Top        Float    @default(0) @map("padding_r2_top")
  paddingR2Right      Float    @default(0) @map("padding_r2_right")
  paddingR2Bottom     Float    @default(0) @map("padding_r2_bottom")
  paddingR2Left       Float    @default(0) @map("padding_r2_left")
  paddingSyncRegions  Boolean? @map("padding_sync_regions")
  viewMode            String   @default("side-by-side") @map("view_mode")
  isBackFlipped       Boolean? @map("is_back_flipped")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("layout_details")
}
